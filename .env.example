
# --- Port Configurations ---
EUREKA_SERVER_PORT=8761
API_GATEWAY_PORT=8080
BUDGET_SERVICE_PORT=8081

# --- Eureka Discovery Service ---
EUREKA_HOSTNAME=localhost
EUREKA_USER=eureka
EUREKA_PASSWORD=your_eureka_password_here
EUREKA_CLIENT_SERVICE_URL=http://eureka:your_eureka_password_here@localhost:8761/eureka/


# --- Database Credentials & URL (Budget Service) ---
DB_URL=jdbc:postgresql://localhost:5432/budget_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# --- Database Pool (Hikari) Configurations ---
DB_MAX_POOL_SIZE=10
DB_MIN_IDLE=2
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=20000
DB_MAX_LIFETIME=1800000

# --- Flyway Migrations ---
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=true
FLYWAY_BASELINE_VERSION=1
FLYWAY_OUT_OF_ORDER=false
FLYWAY_VALIDATE_ON_MIGRATE=true

# --- Actuator Monitoring ---
ACTUATOR_EXPOSE_ENDPOINTS=health,info,metrics,prometheus
ACTUATOR_HEALTH_SHOW_DETAILS=always

# --- OpenAPI / Swagger UI ---
SWAGGER_UI_ENABLED=true
OPENAPI_API_DOCS_PATH=/v3/api-docs
SWAGGER_UI_PATH=/swagger-ui.html

# --- Features ---
VIRTUAL_THREADS_ENABLED=true
